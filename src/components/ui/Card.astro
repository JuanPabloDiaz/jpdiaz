---
import Tags from '@components/ui/Tags.astro';
import OpenOutline from '@components/icons/OpenOutline.astro';
import GitHub from '@components/icons/GitHub.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    github_link?: string;
    link?: string;
    img_alt: string;
    title: string;
    description: string;
    tags: string[];
    imageData: { default: ImageMetadata };
    className?: string;
}

const {
    github_link,
    link,
    img_alt,
    title,
    description,
    tags,
    imageData,
    className = '',
} = Astro.props;
---

<article class={`project-slide ${className}`}>
    <div class="relative aspect-square overflow-hidden rounded-lg">
        <Image
            src={imageData.default}
            alt={img_alt}
            width={300}
            height={300}
            class="h-full w-full object-cover transition-transform duration-300 hover:scale-110"
        />
        <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/70 p-4 text-white opacity-0 transition-opacity duration-300 hover:opacity-100">
            <h3 class="text-xl font-bold">{title}</h3>
            <p class="mt-2 text-sm">{description}</p>
            <div class="mt-4 flex gap-2">
                {github_link && (
                    <a
                        href={github_link}
                        target="_blank"
                        class="rounded-full bg-white/20 p-2 backdrop-blur-sm transition-colors hover:bg-white/40"
                        aria-label={`View ${title} on GitHub`}
                    >
                        <GitHub class="h-5 w-5" />
                    </a>
                )}
                {link && (
                    <a
                        href={link}
                        target="_blank"
                        class="rounded-full bg-white/20 p-2 backdrop-blur-sm transition-colors hover:bg-white/40"
                        aria-label={`Visit ${title} website`}
                    >
                        <OpenOutline class="h-5 w-5" />
                    </a>
                )}
            </div>
        </div>
    </div>
    <div class="mt-2">
        <Tags tags={tags} />
    </div>
</article>
