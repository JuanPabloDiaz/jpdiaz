---
import Button from '@components/ui/Button.astro';
import ToggleTheme from '@components/ui/ToggleTheme.astro';
import { Astronav, MenuItems, MenuIcon, OpenIcon, CloseIcon } from 'astro-navbar';
import Link from '@components/ui/Link.astro';
import Home from '@components/icons/Home.astro';
import MenuOpen from '@components/icons/MenuOpen.astro';
import MenuClose from '@components/icons/MenuClose.astro';
import { languages, ui } from '../i18n/ui';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

type NavKey = keyof typeof ui.en;

interface Props {
	menu: Array<{ title: string; path: string }>;
	button?: boolean;
}

const { menu, button = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get the pathname without the lang prefix
const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';

// Create URLs for language switcher
const otherLang = lang === 'en' ? 'es' : 'en';
const redirectPath = currentPath === '/' ? `/${otherLang}` : `/${otherLang}${currentPath}`;
---

<header class="sticky top-0 z-50 w-full md:my-5">
	<Astronav>
		<nav
			class="flex flex-col justify-end px-2 md:flex-row md:items-center md:space-x-16 lg:px-8 xl:px-20"
		>
			<div class="flex h-10 items-center justify-between gap-4">
				<div class="block md:hidden">
					<ToggleTheme />
				</div>
				<div class="flex items-center space-x-2 ml-4">
					<a 
						href={redirectPath}
						class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
						aria-label={`Switch to ${languages[otherLang]} version`}
					>
						{languages[otherLang]}
					</a>
				</div>
				<div class="block md:hidden">
					<MenuIcon>
						<OpenIcon class="text-black dark:text-white">
							<MenuOpen />
						</OpenIcon>
						<CloseIcon class="text-black dark:text-white">
							<MenuClose />
						</CloseIcon>
					</MenuIcon>
				</div>
			</div>

			<MenuItems class="scrollMenu hidden space-y-2 pb-2 pt-1 md:flex md:space-y-0 md:py-0">
				{button && (
					<Button
						style="secondary"
						size="sm"
						name={t('nav.resume')}
						href={`/${lang}/resume`}
						rel="noopener noreferrer"
						class="flex flex-1 items-center justify-center md:w-20"
					>
						{t('nav.resume')}
					</Button>
				)}
				{
					menu.map((item) => (
						<ul class="flex flex-col md:w-max md:flex-1 md:flex-row">
							<li class="flex items-center justify-end">
								<Link 
									text={t(`nav.${item.title.toLowerCase()}` as NavKey)} 
									ariaLabel="navigation link" 
									href={`/${lang}${item.path}`} 
								/>
							</li>
						</ul>
					))
				}
			</MenuItems>
		</nav>
	</Astronav>
</header>

<style>
	nav {
		animation: nav-shadown 1s linear both;
		animation-timeline: scroll();
		animation-range: 0 100px;
	}

	@keyframes nav-shadown {
		to {
			@apply justify-center rounded-lg text-sm;
		}
	}

	.scrollMenu {
		animation: menu-effect 1s linear both;
		animation-timeline: scroll();
		animation-range: 0 100px;
	}

	@keyframes menu-effect {
		to {
			@apply rounded-lg bg-brown/40 shadow-lg ring-1 ring-white/10 backdrop-blur;
		}
	}
</style>
