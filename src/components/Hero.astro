---
import CallToAction from '@components/CallToAction.astro';
import About from './About.astro';
import { Image } from 'astro:assets';
import juanImage from '@assets/images/juan.jpg';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section data-testid="hero" id="hero" class="mb-0 mt-0 h-auto text-center md:mb-24">
	<main class="flex flex-col-reverse items-center justify-center lg:flex-row">
		<div class="my-10 flex flex-col items-center lg:mb-0 lg:w-1/2">
			<div>
				<h1
					class="mb-10 font-monospace text-2xl text-black dark:text-white lg:text-4xl"
					style="font-display: swap;"
				>
					{t('hero.greeting')} <span class="text-orange">Juan Diaz</span>
					<br />
					{t('hero.title')}
				</h1>
				<p class="text-lg text-gray-600 dark:text-gray-300">
					{t('hero.subtitle')}
				</p>
			</div>
			<div class="mb-10">
				<CallToAction button />
			</div>
		</div>
		<div data-testid="hero-img" class="my-10 flex w-1/2 items-center justify-center">
			<Image
				class="rounded-full opacity-90 shadow-orange/50 duration-75 hover:scale-105 hover:transform hover:opacity-50 hover:shadow-2xl"
				src={juanImage}
				alt="Juan Diaz"
				format="jpg"
				width={450}
				height={450}
				quality={100}
				loading="lazy"
			/>
		</div>
	</main>
	<About />
</section>
